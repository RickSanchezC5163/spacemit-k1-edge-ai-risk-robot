<?xml version="1.0"?>
<sdf version="1.9">
  <world name="tracked_robot_world">
    <physics name="default_physics" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>12 12</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>12 12</size>
            </plane>
          </geometry>
          <material>
            <diffuse>0.82 0.82 0.78 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="outer_north">
      <static>true</static>
      <pose>0 3 0.25 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>6.0 0.08 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>6.0 0.08 0.5</size></box></geometry><material><diffuse>0.45 0.47 0.50 1</diffuse></material></visual></link>
    </model>
    <model name="outer_south">
      <static>true</static>
      <pose>0 -3 0.25 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>6.0 0.08 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>6.0 0.08 0.5</size></box></geometry><material><diffuse>0.45 0.47 0.50 1</diffuse></material></visual></link>
    </model>
    <model name="outer_east">
      <static>true</static>
      <pose>3 0 0.25 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.08 6.0 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.08 6.0 0.5</size></box></geometry><material><diffuse>0.45 0.47 0.50 1</diffuse></material></visual></link>
    </model>
    <model name="outer_west">
      <static>true</static>
      <pose>-3 0 0.25 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.08 6.0 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.08 6.0 0.5</size></box></geometry><material><diffuse>0.45 0.47 0.50 1</diffuse></material></visual></link>
    </model>

    <model name="wall_nw_vertical">
      <static>true</static>
      <pose>-1.45 1.55 0.25 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.08 2.1 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.08 2.1 0.5</size></box></geometry><material><diffuse>0.28 0.34 0.42 1</diffuse></material></visual></link>
    </model>
    <model name="wall_ne_vertical">
      <static>true</static>
      <pose>1.45 1.15 0.25 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.08 1.4 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.08 1.4 0.5</size></box></geometry><material><diffuse>0.28 0.34 0.42 1</diffuse></material></visual></link>
    </model>
    <model name="wall_sw_vertical">
      <static>true</static>
      <pose>-1.1 -1.4 0.25 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.08 1.5 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.08 1.5 0.5</size></box></geometry><material><diffuse>0.28 0.34 0.42 1</diffuse></material></visual></link>
    </model>
    <model name="wall_se_vertical">
      <static>true</static>
      <pose>1.2 -1.55 0.25 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.08 1.3 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.08 1.3 0.5</size></box></geometry><material><diffuse>0.28 0.34 0.42 1</diffuse></material></visual></link>
    </model>

    <model name="wall_north_corridor">
      <static>true</static>
      <pose>0.35 1.7 0.25 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>1.6 0.08 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>1.6 0.08 0.5</size></box></geometry><material><diffuse>0.28 0.34 0.42 1</diffuse></material></visual></link>
    </model>
    <model name="wall_center_corridor">
      <static>true</static>
      <pose>-0.25 0.55 0.25 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>1.25 0.08 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>1.25 0.08 0.5</size></box></geometry><material><diffuse>0.28 0.34 0.42 1</diffuse></material></visual></link>
    </model>
    <model name="wall_south_corridor">
      <static>true</static>
      <pose>0.2 -0.85 0.25 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>1.8 0.08 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>1.8 0.08 0.5</size></box></geometry><material><diffuse>0.28 0.34 0.42 1</diffuse></material></visual></link>
    </model>

    <model name="box_landmark_a">
      <static>true</static>
      <pose>2.25 1.9 0.2 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.35 0.35 0.4</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.35 0.35 0.4</size></box></geometry><material><diffuse>0.64 0.29 0.22 1</diffuse></material></visual></link>
    </model>
    <model name="box_landmark_b">
      <static>true</static>
      <pose>-2.15 -1.85 0.2 0 0 0</pose>
      <link name="link"><collision name="collision"><geometry><box><size>0.40 0.30 0.4</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.40 0.30 0.4</size></box></geometry><material><diffuse>0.26 0.52 0.43 1</diffuse></material></visual></link>
    </model>
  </world>
</sdf>
