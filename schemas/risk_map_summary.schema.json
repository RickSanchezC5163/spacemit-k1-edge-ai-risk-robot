{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "risk_map_summary.schema.json",
  "title": "RiskMapSummary",
  "type": "object",
  "required": ["risk_count_total", "risk_count_by_class", "risk_points", "claim_boundary"],
  "properties": {
    "coordinate_source": {"type": "string"},
    "manual_distance_used_for_mapping": {"type": "boolean"},
    "risk_count_total": {"type": "integer"},
    "risk_count_by_class": {"type": "object"},
    "risk_points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["risk_id", "class_name", "projection_status"],
        "properties": {
          "risk_id": {"type": "string"},
          "class_name": {"type": "string"},
          "confidence": {"type": "number"},
          "image_bbox_xywh": {"type": "array", "items": {"type": "number"}},
          "depth_median_m": {"type": ["number", "null"]},
          "camera_point_xyz_m": {"type": ["object", "null"]},
          "base_point_xyz_m": {"type": ["object", "null"]},
          "odom_point_xy": {"type": ["array", "null"], "items": {"type": "number"}},
          "map_pixel_xy": {"type": ["array", "null"], "items": {"type": "integer"}},
          "projection_status": {"type": "string"},
          "evidence_image_path": {"type": ["string", "null"]},
          "overlay_path": {"type": ["string", "null"]}
        },
        "additionalProperties": true
      }
    },
    "risk_statistics": {"type": "object"},
    "visualization_path": {"type": ["string", "null"]},
    "claim_boundary": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
